<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<ScrollPane fitToWidth="true" fitToHeight="true"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.codecounter.SettingsStageController">

    <VBox spacing="12" prefWidth="400">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Настройки анализа" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

        <Separator/>

        <!-- Режим анализа -->
        <Label text="Режим анализа:"/>

        <!-- Чекбоксы типов токенов — заполняются динамически в контроллере -->
        <Label text="Выберите типы лексем для анализа:"/>

        <VBox fx:id="tokenTypesBox" spacing="5">
            <padding><Insets left="15"/></padding>
        </VBox>

        <Separator/>

        <!-- Прочие настройки -->
        <CheckBox fx:id="showFileDetailsCheck"
                  text="Показывать анализ по каждому файлу (до 100 файлов)"/>
        <CheckBox fx:id="showTokenListCheck"
                  text="Вывести список токенов (на страницах по файлам Excel)"/>

        <Separator/>

        <!-- Кнопки -->
        <HBox spacing="10">
            <Button fx:id="saveBtn"
                    text="Сохранить"
                    onAction="#onSave"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            <Button text="По умолчанию" onAction="#onDefault"/>
            <Button text="Отмена" onAction="#onCancel"/>
        </HBox>

    </VBox>
</ScrollPane>