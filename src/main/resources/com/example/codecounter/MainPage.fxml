<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane minHeight="700.0" minWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.codecounter.MainPageController">
    <VBox alignment="CENTER" spacing="10" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <children>
            <BorderPane>
                <center>
                    <Label alignment="CENTER" contentDisplay="CENTER" text="Анализатор кода" textAlignment="CENTER">
                        <font>
                            <Font name="BebasNeuePro-Regular" size="28.0" />
                        </font>
                        <BorderPane.margin>
                            <Insets top="20.0" />
                        </BorderPane.margin>
                    </Label>
                </center>

                <right>
                    <Button fx:id="settingsBtn" onMouseClicked="#openSettings" prefHeight="30" minHeight="30" prefWidth="30">
                        <BorderPane.margin><Insets right="15" top="25"></Insets></BorderPane.margin>
                    </Button>
                </right>
            </BorderPane>



            <HBox alignment="CENTER" spacing="20">
                <children>
                    <HBox alignment="CENTER" spacing="10">
                        <TextField fx:id="githubUrlField" prefHeight="35" promptText="Ссылка на GitHub-репозиторий..." prefWidth="350" onAction="#loadFromGithub" />
                        <Button fx:id="githubLoadBtn" prefHeight="35" minHeight="30" text="Загрузить из GitHub" onAction="#loadFromGithub" />
                    </HBox>
                    <Label>или</Label>
                    <Button fx:id="chooseDirBtn" minHeight="30" mnemonicParsing="false" onMouseClicked="#chooseDir" prefHeight="35.0" prefWidth="200.0" text="Выбрать папку с проектом" />
                </children>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </HBox>

            <HBox alignment="CENTER" spacing="20">
                <children>
                    <Button fx:id="selectAllBtn" minHeight="30" mnemonicParsing="false" onMouseClicked="#selectAllFiles" prefHeight="35.0" prefWidth="155.0" text="Выбрать все" />
                    <Button fx:id="deselectAllBtn" minHeight="30" mnemonicParsing="false" onMouseClicked="#deselectAllFiles" prefHeight="35.0" prefWidth="155.0" text="Снять все" />
                    <Button fx:id="analyzeBtn" minHeight="30" mnemonicParsing="false" onMouseClicked="#analyzeFiles" prefHeight="35.0" prefWidth="220.0" text="Анализировать выбранные файлы" />
                    <Button fx:id="exportBtn" minHeight="30" disable="true" mnemonicParsing="false" onMouseClicked="#exportToExcel" prefHeight="35.0" prefWidth="160.0" text="Экспорт в Excel" />
                </children>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </HBox>

            <HBox spacing="10" VBox.vgrow="ALWAYS">
                <children>
                    <VBox spacing="5" HBox.hgrow="NEVER">
                        <Label text="Список файлов:" />
                        <HBox spacing="5">
                            <TextField fx:id="searchField" promptText="Поиск файла..." onAction="#searchFiles" HBox.hgrow="ALWAYS" />
                            <Button fx:id="searchBtn" text="Найти" onAction="#searchFiles" />
                        </HBox>
                        <ListView fx:id="fileListView" prefHeight="400.0" prefWidth="300.0" />
                    </VBox>

                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Результаты анализа:" />
                        <TextArea fx:id="outputArea" prefHeight="432.0" wrapText="true" />
                    </VBox>
                </children>
                <VBox.margin>
                    <Insets left="10.0" right="10.0" top="10.0" />
                </VBox.margin>
            </HBox>

            <VBox alignment="CENTER">
                <ProgressBar fx:id="analysisProgressBar" prefWidth="400.0" progress="0.0" visible="false" />
                <Label fx:id="progressLb" alignment="CENTER" contentDisplay="CENTER" text="" textAlignment="CENTER" visible="false">
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Label>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </VBox>

            <VBox alignment="CENTER">
                <Label fx:id="resultLb" alignment="CENTER" contentDisplay="CENTER" text="Выберите папку" textAlignment="CENTER">
                    <font>
                        <Font name="BebasNeuePro-Regular" size="18.0" />
                    </font>
                </Label>
                <VBox.margin>
                    <Insets bottom="20.0" />
                </VBox.margin>
            </VBox>
        </children>
    </VBox>
</AnchorPane>
